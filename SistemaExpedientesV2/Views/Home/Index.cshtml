@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mt-5">

    <h1 class="display-3 fw-bold text-primary">
        Sistema de Expedientes Académicos
    </h1>

    <p class="lead mt-4">
        Colegio San José
    </p>

    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135755.png"
         width="220"
         class="mt-4 mb-4" />

    <div class="container">
        <div class="row justify-content-center mt-4">

            <div class="col-md-3">
                <div class="card shadow p-3 mb-4 bg-white rounded">
                    <h5>Alumnos</h5>
                    <p>Gestión completa de estudiantes.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow p-3 mb-4 bg-white rounded">
                    <h5>Materias</h5>
                    <p>Administración de materias académicas.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow p-3 mb-4 bg-white rounded">
                    <h5>Expedientes</h5>
                    <p>Registro de notas y observaciones.</p>
                </div>
            </div>

        </div>
    </div>

</div>